{"ast":null,"code":"import{createSlice}from\"@reduxjs/toolkit\";const initialState={items:[]};const wishListSlice=createSlice({name:\"wishlist\",initialState,reducers:{addToWishList:(state,action)=>{state.items.push(action.payload);},removeFromWishList:(state,action)=>{state.items=state.items.filter(item=>item.id!==action.payload.id);},clearWishList:state=>{state.items=[];}}});export const{addToWishList,removeFromWishList,clearWishList}=wishListSlice.actions;export default wishListSlice.reducer;","map":{"version":3,"names":["createSlice","initialState","items","wishListSlice","name","reducers","addToWishList","state","action","push","payload","removeFromWishList","filter","item","id","clearWishList","actions","reducer"],"sources":["/workspace/src/Features/Wishlist/wishListSlice.js"],"sourcesContent":["import { createSlice } from \"@reduxjs/toolkit\";\n\nconst initialState = {\n  items: [],\n};\n\nconst wishListSlice = createSlice({\n  name: \"wishlist\",\n  initialState,\n  reducers: {\n    addToWishList: (state, action) => {\n      state.items.push(action.payload);\n    },\n    removeFromWishList: (state, action) => {\n      state.items = state.items.filter((item) => item.id !== action.payload.id);\n    },\n    clearWishList: (state) => {\n      state.items = [];\n    },\n  },\n});\n\nexport const { addToWishList, removeFromWishList, clearWishList } =\n  wishListSlice.actions;\n\nexport default wishListSlice.reducer;\n"],"mappings":"AAAA,OAASA,WAAW,KAAQ,kBAAkB,CAE9C,KAAM,CAAAC,YAAY,CAAG,CACnBC,KAAK,CAAE,EACT,CAAC,CAED,KAAM,CAAAC,aAAa,CAAGH,WAAW,CAAC,CAChCI,IAAI,CAAE,UAAU,CAChBH,YAAY,CACZI,QAAQ,CAAE,CACRC,aAAa,CAAEA,CAACC,KAAK,CAAEC,MAAM,GAAK,CAChCD,KAAK,CAACL,KAAK,CAACO,IAAI,CAACD,MAAM,CAACE,OAAO,CAAC,CAClC,CAAC,CACDC,kBAAkB,CAAEA,CAACJ,KAAK,CAAEC,MAAM,GAAK,CACrCD,KAAK,CAACL,KAAK,CAAGK,KAAK,CAACL,KAAK,CAACU,MAAM,CAAEC,IAAI,EAAKA,IAAI,CAACC,EAAE,GAAKN,MAAM,CAACE,OAAO,CAACI,EAAE,CAAC,CAC3E,CAAC,CACDC,aAAa,CAAGR,KAAK,EAAK,CACxBA,KAAK,CAACL,KAAK,CAAG,EAAE,CAClB,CACF,CA