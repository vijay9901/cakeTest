# CakeFest - Environment Configuration
REACT_APP_NAME=CakeFest
REACT_APP_VERSION=1.0.0
REACT_APP_DESCRIPTION=Premium Cakes & Desserts E-commerce

# API Configuration (for future backend integration)
REACT_APP_API_URL=https://api.cakefest.com
REACT_APP_PAYMENT_GATEWAY_URL=https://payment.cakefest.com

# Social Media Links
REACT_APP_FACEBOOK_URL=https://facebook.com/cakefest
REACT_APP_INSTAGRAM_URL=https://instagram.com/cakefest
REACT_APP_TWITTER_URL=https://twitter.com/cakefest

# Contact Information
REACT_APP_PHONE=+91-9876-543-210
REACT_APP_EMAIL=orders@cakefest.com
REACT_APP_ADDRESS=Broke Field, Bangalore - 560085

# Business Hours
REACT_APP_BUSINESS_HOURS=Mon-Sat: 7AM-8PM, Sun: 8AM-6PM

# Features Toggle
REACT_APP_ENABLE_3D_MODEL=true
REACT_APP_ENABLE_REVIEWS=true
REACT_APP_ENABLE_WISHLIST=true
REACT_APP_ENABLE_NOTIFICATIONS=true

# SEO
REACT_APP_SITE_URL=https://cakefest.netlify.app
REACT_APP_GOOGLE_ANALYTICS_ID=GA-XXXXX-X