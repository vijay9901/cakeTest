# Sweet Dreams Bakery - Environment Configuration
REACT_APP_NAME=Sweet Dreams Bakery
REACT_APP_VERSION=1.0.0
REACT_APP_DESCRIPTION=Premium Cakes & Desserts E-commerce

# API Configuration (for future backend integration)
REACT_APP_API_URL=https://api.sweet-dreams-bakery.com
REACT_APP_PAYMENT_GATEWAY_URL=https://payment.sweet-dreams-bakery.com

# Social Media Links
REACT_APP_FACEBOOK_URL=https://facebook.com/sweetdreamsbakery
REACT_APP_INSTAGRAM_URL=https://instagram.com/sweetdreamsbakery
REACT_APP_TWITTER_URL=https://twitter.com/sweetdreamsbake

# Contact Information
REACT_APP_PHONE=+1-555-CAKE-123
REACT_APP_EMAIL=orders@sweet-dreams-bakery.com
REACT_APP_ADDRESS=123 Baker Street, Sweet City, SC 12345

# Business Hours
REACT_APP_BUSINESS_HOURS=Mon-Sat: 7AM-8PM, Sun: 8AM-6PM

# Features Toggle
REACT_APP_ENABLE_3D_MODEL=true
REACT_APP_ENABLE_REVIEWS=true
REACT_APP_ENABLE_WISHLIST=true
REACT_APP_ENABLE_NOTIFICATIONS=true

# SEO
REACT_APP_SITE_URL=https://sweet-dreams-bakery.netlify.app
